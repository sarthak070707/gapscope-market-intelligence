// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Product {
  id           String   @id @default(cuid())
  name         String
  tagline      String
  description  String
  url          String
  category     String
  upvotes      Int      @default(0)
  launchDate   String
  features     String   @default("[]") // JSON string of features
  pricing      String   @default("Unknown")
  comments     String   @default("[]") // JSON string of comment summaries
  reviewScore  Float    @default(0)
  sourceUrl    String   @default("")
  dataSource   String   @default("web_search") // web_search | cached | database | ai_knowledge | seed
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  gaps         Gap[]
  complaints   Complaint[]
}

model Gap {
  id           String   @id @default(cuid())
  productId    String
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  gapType      String   // missing_feature, weak_ux, expensive, underserved, overcrowded
  title        String
  description  String
  evidence     String   @default("")
  // Evidence Detail (JSON)
  evidenceDetail  String   @default("{}") // JSON: { similarProducts, repeatedComplaints, launchFrequency, commentSnippets, pricingOverlap }
  // Why This Matters
  whyThisMatters  String   @default("")
  // Sub-Niche (JSON)
  subNiche        String   @default("{}") // JSON: { name, description, parentCategory, opportunityScore }
  // Affected Products (JSON array)
  affectedProducts String  @default("[]") // JSON: [{ name, pricing, strengths, weaknesses }]
  // Underserved Users (JSON array)
  underservedUsers String  @default("[]") // JSON: [{ userGroup, description, evidence, opportunityScore }]
  severity     String   @default("medium") // low, medium, high

  // NEW: "WHY NOW?" Analysis (JSON)
  whyNow          String   @default("{}") // JSON: { marketGrowthDriver, incumbentWeakness, timingAdvantage, catalystEvents }

  // NEW: Execution Difficulty (JSON)
  executionDifficulty String @default("{}") // JSON: { level, demandLevel, competitionLevel, technicalComplexity, timeToMvp, estimatedBudget, keyChallenges }

  // NEW: False Opportunity Detection (JSON)
  falseOpportunity  String @default("{}") // JSON: { isFalseOpportunity, reason, estimatedMarketSize, riskFactors, verdict }

  // NEW: Founder Fit Suggestions (JSON)
  founderFit        String @default("{}") // JSON: { bestFit, rationale, requiredSkills, idealTeamSize }

  // NEW: Source Transparency (JSON)
  sourceTransparency String @default("{}") // JSON: { sourcePlatforms, totalComments, complaintFrequency, reviewSources, dataFreshness, confidenceLevel }

  // NEW: Why Existing Products Fail (JSON)
  whyExistingProductsFail String @default("{}") // JSON: { rootCause, userImpact, missedByCompetitors }

  // NEW: Market Quadrant Position (JSON)
  marketQuadrant    String @default("{}") // JSON: { competitionScore, opportunityScore, quadrant, label }

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Complaint {
  id           String   @id @default(cuid())
  productId    String
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  text         String
  category     String   // pricing, missing_feature, performance, ux, support, integration
  sentiment    String   @default("negative") // negative, neutral, mixed
  frequency    Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Opportunity {
  id             String   @id @default(cuid())
  title          String
  description    String
  category       String
  saturation     String   @default("medium") // low, medium, high
  saturationScore Float   @default(50)
  gapEvidence    String   @default("[]") // JSON string of gap evidence
  complaintRefs  String   @default("[]") // JSON string of complaint references
  trendSignals   String   @default("[]") // JSON string of trend signals
  qualityScore   Float    @default(0)
  // Evidence Detail (JSON)
  evidenceDetail  String   @default("{}") // JSON: { similarProducts, repeatedComplaints, launchFrequency, commentSnippets, pricingOverlap }
  // Opportunity Score (JSON)
  opportunityScore String  @default("{}") // JSON: { complaintFrequency, competitionDensity, pricingDissatisfaction, launchGrowth, underservedAudience, total, explanation }
  // Why This Matters
  whyThisMatters  String   @default("")
  // Sub-Niche (JSON)
  subNiche        String   @default("{}") // JSON: { name, description, parentCategory, opportunityScore }
  // Affected Products (JSON array)
  affectedProducts String  @default("[]") // JSON: [{ name, pricing, strengths, weaknesses }]
  // Underserved Users (JSON array)
  underservedUsers String  @default("[]") // JSON: [{ userGroup, description, evidence, opportunityScore }]

  // NEW: "WHY NOW?" Analysis (JSON)
  whyNow          String   @default("{}") // JSON: { marketGrowthDriver, incumbentWeakness, timingAdvantage, catalystEvents }

  // NEW: Execution Difficulty (JSON)
  executionDifficulty String @default("{}") // JSON: { level, demandLevel, competitionLevel, technicalComplexity, timeToMvp, estimatedBudget, keyChallenges }

  // NEW: False Opportunity Detection (JSON)
  falseOpportunity  String @default("{}") // JSON: { isFalseOpportunity, reason, estimatedMarketSize, riskFactors, verdict }

  // NEW: Founder Fit Suggestions (JSON)
  founderFit        String @default("{}") // JSON: { bestFit, rationale, requiredSkills, idealTeamSize }

  // NEW: Source Transparency (JSON)
  sourceTransparency String @default("{}") // JSON: { sourcePlatforms, totalComments, complaintFrequency, reviewSources, dataFreshness, confidenceLevel }

  // NEW: Why Existing Products Fail (JSON)
  whyExistingProductsFail String @default("{}") // JSON: { rootCause, userImpact, missedByCompetitors }

  // NEW: Market Quadrant Position (JSON)
  marketQuadrant    String @default("{}") // JSON: { competitionScore, opportunityScore, quadrant, label }

  isSaved        Boolean  @default(false)
  isGenerated    Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Trend {
  id          String   @id @default(cuid())
  category    String
  name        String
  description String
  growthRate  Float    @default(0)
  direction   String   @default("growing") // growing, declining, stable
  dataPoints  String   @default("[]") // JSON string of data points
  period      String   @default("") // e.g., "3 months", "6 months"
  // Sub-Niches (JSON array)
  subNiches      String   @default("[]") // JSON: [{ name, description, parentCategory, opportunityScore }]
  // Underserved Users (JSON array)
  underservedUsers String @default("[]") // JSON: [{ userGroup, description, evidence, opportunityScore }]

  // NEW: "WHY NOW?" Analysis (JSON)
  whyNow          String   @default("{}") // JSON: { marketGrowthDriver, incumbentWeakness, timingAdvantage, catalystEvents }

  // NEW: Source Transparency (JSON)
  sourceTransparency String @default("{}") // JSON: { sourcePlatforms, totalComments, complaintFrequency, reviewSources, dataFreshness, confidenceLevel }

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ScanJob {
  id          String   @id @default(cuid())
  status      String   @default("pending") // pending, running, completed, failed
  category    String
  stage       String   @default("") // Current processing stage (e.g., "WEB_SEARCH", "LLM_EXTRACT")
  resultCount Int      @default(0)
  errors      String   @default("[]") // JSON string of errors
  productIds  String   @default("[]") // JSON string of saved product IDs
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
